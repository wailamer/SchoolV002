@model AttendanceBoardVm
<div class="card"><h3>لوحة الغياب</h3><form method="post" asp-action="Save"><input type="hidden" asp-for="ClassRoomId"/><input asp-for="Date" type="date"/><table><tr><th>الطالب</th><th>حاضر</th></tr>@for(int i=0;i<Model.Rows.Count;i++){<tr><td>@Model.Rows[i].StudentName<input type="hidden" asp-for="Rows[i].StudentRecordId"/><input type="hidden" asp-for="Rows[i].StudentName"/></td><td><input asp-for="Rows[i].IsPresent"/></td></tr>}</table><button>حفظ</button></form></div>
