@model AttendanceBoardVm <div class="card"><form asp-action="Save" method="post"><input asp-for="Grade"/><input asp-for="Section"/><input asp-for="Date" type="date"/>@for(int i=0;i<Model.Students.Count;i++){<input type="hidden" name="Students[@i].StudentRecordId" value="@Model.Students[i].StudentRecordId"/><label>@Model.Students[i].StudentName</label><select name="Students[@i].IsPresent"><option value="true">حاضر</option><option value="false">غائب</option></select>}<button>حفظ</button></form></div>