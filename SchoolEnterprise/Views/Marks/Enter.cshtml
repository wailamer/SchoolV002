@model MarkEntryVm
<div class="card"><h3>إدخال العلامات</h3><form method="post" asp-action="Save"><input type="hidden" asp-for="ClassRoomId"/><input type="hidden" asp-for="SubjectId"/><input type="hidden" asp-for="Semester"/><table><tr><th>سجل</th><th>أنشطة</th><th>شفهي</th><th>وظائف</th><th>امتحان</th></tr>@for(int i=0;i<Model.Marks.Count;i++){<tr><td>@Model.Marks[i].StudentRecordId<input type="hidden" asp-for="Marks[i].MarkId"/><input type="hidden" asp-for="Marks[i].StudentRecordId"/><input type="hidden" asp-for="Marks[i].SubjectId"/><input type="hidden" asp-for="Marks[i].Semester"/></td><td><input asp-for="Marks[i].Activities"/></td><td><input asp-for="Marks[i].Oral"/></td><td><input asp-for="Marks[i].Homework"/></td><td><input asp-for="Marks[i].Exam"/></td></tr>}</table><button>حفظ</button></form></div>
