@{ var marks = ViewBag.Marks as List<StudentMark>; }<table><tr><th>المادة</th><th>الفصل</th><th>أنشطة</th><th>شفهي</th><th>وظائف</th><th>امتحان</th><th>المجموع</th><th>التقدير</th></tr>@foreach(var m in marks ?? new List<StudentMark>()){<tr><td>@m.SubjectId</td><td>@m.Semester</td><td>@m.Activities</td><td>@m.Oral</td><td>@m.Homework</td><td>@m.Exam</td><td>@m.Total</td><td>@m.GradeText</td></tr>}</table>