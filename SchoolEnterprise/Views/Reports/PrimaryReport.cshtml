@model PrimaryReportVm
<div class="card"><h2>@ViewBag.Settings?.SchoolName</h2><h3>جلاء الحلقة الأولى</h3><p>الطالب: @Model.StudentName</p><p>الأب: @Model.FatherName | الأم: @Model.MotherName</p><p>الصف: @Model.GradeSection | العام: @Model.AcademicYear</p><table><tr><th>الفصل الأول</th><th>الفصل الثاني</th><th>المحصلة</th><th>النسبة</th><th>النتيجة</th></tr><tr><td>@Model.FirstSemester</td><td>@Model.SecondSemester</td><td>@Model.Total</td><td>@Model.Percentage</td><td>@Model.FinalResult</td></tr></table><p>التوجيهات: @ViewBag.Settings?.GuidanceText</p><button onclick="window.print()">طباعة</button></div>