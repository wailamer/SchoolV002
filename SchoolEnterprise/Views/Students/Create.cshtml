@model StudentCreateVm
<div class="card"><h3>إضافة طالب</h3><form method="post" enctype="multipart/form-data">
<input asp-for="MinistryCode" placeholder="الكود الوزاري"/><input asp-for="FirstName" placeholder="الاسم"/><input asp-for="FatherName" placeholder="اسم الأب"/><input asp-for="GrandFatherName" placeholder="اسم الجد"/><input asp-for="LastName" placeholder="الكنية"/><input asp-for="MotherName" placeholder="اسم الأم"/><input asp-for="BirthDate" type="date"/><input asp-for="Phone" placeholder="الهاتف"/><input asp-for="Address" placeholder="العنوان"/><input asp-for="AcademicYear" placeholder="العام الدراسي"/><input asp-for="ClassRoomId" placeholder="رقم الشعبة"/><input asp-for="RollNumber" placeholder="الترتيب"/><input asp-for="Photo" type="file"/><button>حفظ</button></form></div>
