@model IEnumerable<StudentRegistration><div class="card"><a asp-action="Create">إضافة طالب</a><table><tr><th>الاسم</th><th>الكود</th><th></th></tr>@foreach(var s in Model){<tr><td>@s.FirstName @s.FatherName</td><td>@s.MinistryCode</td><td><a asp-action="Details" asp-route-id="@s.StudentId">تفاصيل</a> <a asp-action="Edit" asp-route-id="@s.StudentId">تعديل</a> <a asp-action="Promote" asp-route-id="@s.StudentId">ترفيع</a></td></tr>}</table></div>