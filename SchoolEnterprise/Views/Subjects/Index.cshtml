@model List<Subject>
<div class="card"><a asp-action="Create">إضافة مادة</a></div>
<table><tr><th>المادة</th><th>الصف</th><th></th></tr>@foreach(var s in Model){<tr><td>@s.Name</td><td>@s.Grade</td><td><a asp-action="Edit" asp-route-id="@s.SubjectId">تعديل</a> | <a asp-action="Delete" asp-route-id="@s.SubjectId">حذف</a></td></tr>}</table>
