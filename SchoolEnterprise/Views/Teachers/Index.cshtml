@model List<Teacher>
<div class="card"><a asp-action="Create">إضافة معلم</a></div>
<table><tr><th>الاسم</th><th>الهاتف</th><th></th></tr>@foreach(var t in Model){<tr><td>@t.FullName</td><td>@t.Phone</td><td><a asp-action="Edit" asp-route-id="@t.TeacherId">تعديل</a> | <a asp-action="Delete" asp-route-id="@t.TeacherId">حذف</a></td></tr>}</table>
